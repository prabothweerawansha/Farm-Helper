rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    // Collection: users
    // Document ID: {userId}
    // Fields:
    //   - startDate: string (required)
    //   - reminderTime: string (required)
    //   - language: string (required, 'en' or 'si')
    //   - progress: map (required)
    //   - customTasks: list (required)
    // ===============================================================

    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isValidUserProfile() {
      let data = request.resource.data;
      return data.keys().hasAll(['startDate', 'reminderTime', 'language', 'progress', 'customTasks']) &&
             data.startDate is string &&
             data.reminderTime is string &&
             data.language in ['en', 'si'] &&
             data.progress is map &&
             data.customTasks is list;
    }

    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUserProfile();
      allow update: if isOwner(userId) && isValidUserProfile();
      allow delete: if isOwner(userId);
    }
  }
}
