{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "description": "Stores user preferences and progress for plant care",
      "type": "object",
      "properties": {
        "startDate": { "type": "string", "description": "Start date of the care cycle" },
        "reminderTime": { "type": "string", "description": "Time for daily reminders" },
        "language": { "type": "string", "enum": ["en", "si"], "description": "Preferred language" },
        "progress": { "type": "object", "description": "Map of day number to boolean completion status" },
        "customTasks": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "day": { "type": "number" },
              "item": { "type": "string" },
              "dosage": { "type": "string" },
              "type": { "type": "string", "enum": ["treatment", "rest"] }
            },
            "required": ["id", "day", "item", "type"]
          }
        }
      },
      "required": ["startDate", "reminderTime", "language", "progress", "customTasks"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": { "$ref": "#/entities/UserProfile" },
      "description": "User profile document containing settings and tasks"
    }
  }
}
